# --- Django Settings ---
DEBUG=True
SECRET_KEY=supersecretkey123
ALLOWED_HOSTS=*

# --- Database (MySQL) ---
DATABASE_NAME=fasocommerce
DATABASE_USER=faso_user
DATABASE_PASSWORD=fasopass
DATABASE_HOST=db
DATABASE_PORT=3306

# --- Celery & Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT & Auth ---
JWT_SECRET=jwtsecretkey123
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=3600
REFRESH_TOKEN_LIFETIME=86400

# --- Payment APIs ---
ORANGE_MONEY_API_KEY=your_orange_money_api_key
MOOV_MONEY_API_KEY=your_moov_money_api_key

# --- Email (pour OTP et notifications) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
